	<!--Name of the mod to display to players-->
	<DisplayName Value="Pre-Select Route Vehicles" />
	<!--Short description of the mod-->
	<ShortDescription Value="Choose transit vehicles while planning a route." />
	<!--Long description of the mod. Single line or multi line. Supports minimal markdown subset-->
	<!--LongDescription Value="This is a long description" /-->
	<LongDescription>Tired of the game randomly picking vehicles every time you create a route? Pre-Select Route Vehicles lets you choose them in advance while you are still planning the line. Pick vehicles directly from the route planning toolbox, use multi-select, and keep separate saved selections for different route types. Your selections are remembered and applied to the created route, so new lines use the vehicles you actually want instead of a random pick.
	</LongDescription>

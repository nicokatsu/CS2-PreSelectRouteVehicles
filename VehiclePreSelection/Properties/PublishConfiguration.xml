	<!--Name of the mod to display to players-->
	<DisplayName Value="Route Planning Extension" />
	<!--Short description of the mod-->
	<ShortDescription Value="Choose route vehicles and randomize route colors while planning." />
	<!--Long description of the mod. Single line or multi line. Supports minimal markdown subset-->
	<!--LongDescription Value="This is a long description" /-->
	<LongDescription>Tired of the game giving you a vehicle you did not want to use, or making route colors tedious to manage? Route Planning Extension lets you choose vehicles in advance while you are still planning the line. Pick them directly from the route planning toolbox, use multi-select, save selections for different route types, and optionally enable random route colors with separate toggles per transport type. Random colors are applied when the route is created.
	</LongDescription>
